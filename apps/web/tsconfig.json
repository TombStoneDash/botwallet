{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@botwallet/db": ["../../packages/db/src/index.ts"],
      "@botwallet/db/*": ["../../packages/db/src/*"],
      "@botwallet/ledger": ["../../packages/ledger/src/index.ts"],
      "@botwallet/ledger/*": ["../../packages/ledger/src/*"],
      "@botwallet/policy": ["../../packages/policy/src/index.ts"],
      "@botwallet/policy/*": ["../../packages/policy/src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
